// Função para gerar dados e testar o display
void coleta(void *pvParameters)
{
    float vrms = 0;
    float aux = 0;
    int n = sizeof(sinal)/sizeof(sinal[0])
    ESP_LOGI("Coleta","Init...");
    while(1)
    {
      aux = 0
      for(int i; i < n; i++)
      {
        aux = aux + pow(sinal[i],2)
      }
      
      vrms = sqrt(aux/n)

      xStreamBufferSend(buffer, &vrms, sizeof(dados), 0);

      vTaskDelay(pdMS_TO_TICKS(5000));
    }

}

// Task para exibir informações no display
void display(void *pvParameters)
{
    // Display max 17 char, sem char especial
    float dados;
    char str[7];
    ESP_LOGI("Oled","Init...");
    while(1)
    {
        char form[20] = "TensaoRMS:"; // Precisa ser reatualuizado a cada volta do loop
        // Recebe os dados do buffer
        xStreamBufferReceive(buffer, &dados, sizeof(dados), portMAX_DELAY);
        ESP_LOGI("Oled", "printing");
        // Limpa o display
        ssd1306_clear_screen(&device, false);
        // Converte o valor de 'dados' para uma string 'str'
        snprintf(str, sizeof(str), "%.2f", dados);
        // Concatena 'str' com uma string de formatação 'form'
        strcat(form, str);      
        // printa o valor de 'form' + 'dados'  
        ssd1306_display_text(&device, 0, form, sizeof(form), false);

    }
    
}



// Precisa tertar !!!!
void app_main(void)
{
    vTaskPrioritySet(NULL, 5);

    // Criação Stream Buffer
    // 1 float = 32bits = 4Bytes
    buffer = xStreamBufferCreate(4,1);

    // Criação das tasks
    xTaskCreate(display, "oled", 4096, NULL, 2, NULL);
    xTaskCreate(coleta, "dados", 4096, NULL, 2, NULL);

    // Inicialização do display
    display_init();
}
